@model FoodSafety.MVC.ViewModels.PremisesHistoryViewModel
@using FoodSafety.Domain.Enums

@{
    ViewData["Title"] = "Premises History";
}

<h1 class="mb-3">Historical Records - @Model.Name</h1>

<p class="text-muted mb-4">
    Showing inspections and follow-ups older than @Model.MonthsBack month(s), before @Model.CutoffDate.ToString("dd/MM/yyyy").
</p>

<div class="mb-4">
    <p><strong>Address:</strong> @Model.Address</p>
    <p><strong>Town:</strong> @Model.Town</p>
    <p>
        <strong>Risk Rating:</strong>
        @if (Model.RiskRating == RiskRating.High)
        {
            <span class="badge bg-danger">High</span>
        }
        else if (Model.RiskRating == RiskRating.Medium)
        {
            <span class="badge bg-warning text-dark">Medium</span>
        }
        else
        {
            <span class="badge bg-success">Low</span>
        }
    </p>
</div>

<form method="get" asp-action="History" class="row g-3 mb-4">
    <input type="hidden" name="id" value="@Model.Id" />

    <div class="col-md-4">
        <label class="form-label">Show records older than</label>
        <select name="monthsBack" class="form-select">
            @if (Model.MonthsBack == 1)
            {
                <option value="1" selected>1 month</option>
            }
            else
            {
                <option value="1">1 month</option>
            }

            @if (Model.MonthsBack == 3)
            {
                <option value="3" selected>3 months</option>
            }
            else
            {
                <option value="3">3 months</option>
            }

            @if (Model.MonthsBack == 6)
            {
                <option value="6" selected>6 months</option>
            }
            else
            {
                <option value="6">6 months</option>
            }

            @if (Model.MonthsBack == 12)
            {
                <option value="12" selected>12 months</option>
            }
            else
            {
                <option value="12">12 months</option>
            }
        </select>
    </div>

    <div class="col-md-4 d-flex align-items-end">
        <button type="submit" class="btn btn-primary me-2">Apply</button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Back to Details</a>
    </div>
</form>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h6>Historical Inspections</h6>
                <p class="display-6">@Model.TotalHistoricalInspections</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h6>Historical Fails</h6>
                <p class="display-6 text-danger">@Model.TotalHistoricalFails</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h6>Historical Follow-Ups</h6>
                <p class="display-6 text-primary">@Model.TotalHistoricalFollowUps</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h6>Closed Follow-Ups</h6>
                <p class="display-6 text-success">@Model.TotalHistoricalClosedFollowUps</p>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm mb-4">
            <div class="card-header">Historical Inspection History</div>
            <div class="card-body">
                @if (Model.HistoricalInspections.Any())
                {
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Score</th>
                                <th>Outcome</th>
                                <th>Notes</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.HistoricalInspections)
                            {
                                <tr>
                                    <td>@item.InspectionDate.ToString("dd/MM/yyyy")</td>
                                    <td>@item.Score</td>
                                    <td>
                                        @if (item.Outcome == InspectionOutcome.Fail)
                                        {
                                            <span class="badge bg-danger">Fail</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Pass</span>
                                        }
                                    </td>
                                    <td>@item.Notes</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p>No historical inspections found for this period.</p>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-sm mb-4">
            <div class="card-header">Historical Follow-Up History</div>
            <div class="card-body">
                @if (Model.HistoricalFollowUps.Any())
                {
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Inspection Date</th>
                                <th>Due Date</th>
                                <th>Status</th>
                                <th>Closed Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.HistoricalFollowUps)
                            {
                                <tr class="@(item.IsOverdue ? "table-warning" : "")">
                                    <td>@item.InspectionDate.ToString("dd/MM/yyyy")</td>
                                    <td>@item.DueDate.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        @if (item.Status == FollowUpStatus.Open)
                                        {
                                            if (item.IsOverdue)
                                            {
                                                <span class="badge bg-warning text-dark">Open - Overdue</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-primary">Open</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Closed</span>
                                        }
                                    </td>
                                    <td>@(item.ClosedDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p>No historical follow-ups found for this period.</p>
                }
            </div>
        </div>
    </div>
</div>