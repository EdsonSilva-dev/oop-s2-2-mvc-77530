@model List<FoodSafety.MVC.ViewModels.PremisesListItemViewModel>
@using FoodSafety.Domain.Enums

@{
    ViewData["Title"] = "Premises";
}

<h1 class="mb-4">Premises</h1>

<form method="get" class="row g-3 mb-4">
    <div class="col-md-5">
        <label class="form-label">Search by name</label>
        <input type="text" name="searchTerm" value="@ViewBag.SearchTerm" class="form-control" />
    </div>

    <div class="col-md-4">
        <label class="form-label">Town</label>
        <input type="text" name="town" value="@ViewBag.Town" class="form-control" />
    </div>

    <div class="col-md-3 d-flex align-items-end">
        <button type="submit" class="btn btn-primary me-2">Search</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

@if (User.IsInRole("Admin"))
{
    <p>
        <a asp-action="Create" class="btn btn-success">Create New Premises</a>
    </p>
}

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Name</th>
            <th>Address</th>
            <th>Town</th>
            <th>Risk Rating</th>
            <th>Total Inspections</th>
            <th>Open Follow-Ups</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Address</td>
                <td>@item.Town</td>
                <td>
                    @if (item.RiskRating == RiskRating.High)
                    {
                        <span class="badge bg-danger">High</span>
                    }
                    else if (item.RiskRating == RiskRating.Medium)
                    {
                        <span class="badge bg-warning text-dark">Medium</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Low</span>
                    }
                </td>
                <td>@item.TotalInspections</td>
                <td>@item.OpenFollowUps</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Details</a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-secondary">Edit</a>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
                    {
                        <a asp-controller="Inspections" asp-action="Create" asp-route-premisesId="@item.Id" class="btn btn-sm btn-success">
                            New Inspection
                        </a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>