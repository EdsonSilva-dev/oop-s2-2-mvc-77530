@model FoodSafety.MVC.ViewModels.PremisesDetailsViewModel
@using FoodSafety.Domain.Enums

@{
    ViewData["Title"] = "Premises Details";
}
<p class="text-muted mb-4">
    Review the premises profile, inspection performance, and follow-up history in one place.
</p>
<h1 class="mb-4">@Model.Name</h1>

<div class="mb-4">
    <p><strong>Address:</strong> @Model.Address</p>
    <p><strong>Town:</strong> @Model.Town</p>
    <p>
        <strong>Risk Rating:</strong>
        @if (Model.RiskRating == RiskRating.High)
        {
            <span class="badge bg-danger">High</span>
        }
        else if (Model.RiskRating == RiskRating.Medium)
        {
            <span class="badge bg-warning text-dark">Medium</span>
        }
        else
        {
            <span class="badge bg-success">Low</span>
        }
    </p>
</div>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h6>Total Inspections</h6>
                <p class="display-6">@Model.TotalInspections</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h6>Failed Inspections</h6>
                <p class="display-6 text-danger">@Model.FailedInspections</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h6>Open Follow-Ups</h6>
                <p class="display-6 text-primary">@Model.OpenFollowUps</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h6>Overdue Follow-Ups</h6>
                <p class="display-6 text-warning">@Model.OverdueFollowUps</p>
            </div>
        </div>
    </div>
</div>

<div class="mb-4">
    <h4>Latest Inspection Summary</h4>
    @if (Model.LatestInspectionDate.HasValue)
    {
        <p><strong>Date:</strong> @Model.LatestInspectionDate.Value.ToString("dd/MM/yyyy")</p>
        <p><strong>Score:</strong> @Model.LatestInspectionScore</p>
        <p><strong>Outcome:</strong> @Model.LatestInspectionOutcome</p>
    }
    else
    {
        <p>No inspections recorded yet.</p>
    }
</div>

@if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
{
    <div class="mb-4">
        <a asp-controller="Inspections" asp-action="Create" asp-route-premisesId="@Model.Id" class="btn btn-success">
            Add Inspection
        </a>
    </div>
}

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm mb-4">
            <div class="card-header">Inspection History</div>
            <div class="card-body">
                @if (Model.InspectionHistory.Any())
                {
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Score</th>
                                <th>Outcome</th>
                                <th>Notes</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.InspectionHistory)
                            {
                                <tr>
                                    <td>@item.InspectionDate.ToString("dd/MM/yyyy")</td>
                                    <td>@item.Score</td>
                                    <td>
                                        @if (item.Outcome == InspectionOutcome.Fail)
                                        {
                                            <span class="badge bg-danger">Fail</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Pass</span>
                                        }
                                    </td>
                                    <td>@item.Notes</td>
                                    <td>
                                        @if ((User.IsInRole("Admin") || User.IsInRole("Inspector")) && item.Outcome == InspectionOutcome.Fail)
                                        {
                                            <a asp-controller="FollowUps" asp-action="Create" asp-route-inspectionId="@item.InspectionId" class="btn btn-sm btn-warning">
                                                Add Follow-Up
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p>No inspections found.</p>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-sm mb-4">
            <div class="card-header">Follow-Up History</div>
            <div class="card-body">
                @if (Model.FollowUpHistory.Any())
                {
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Inspection Date</th>
                                <th>Due Date</th>
                                <th>Status</th>
                                <th>Closed Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.FollowUpHistory)
                            {
                                <tr class="@(item.IsOverdue ? "table-warning" : "")">
                                    <td>@item.InspectionDate.ToString("dd/MM/yyyy")</td>
                                    <td>@item.DueDate.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        @if (item.Status == FollowUpStatus.Open)
                                        {
                                            if (item.IsOverdue)
                                            {
                                                <span class="badge bg-warning text-dark">Open - Overdue</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-primary">Open</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Closed</span>
                                        }
                                    </td>
                                    <td>@(item.ClosedDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p>No follow-ups found.</p>
                }
                
            </div>
            <a asp-action="Index" class="btn btn-outline-secondary mb-3">Back to Premises</a>
        </div>
    </div>
</div>