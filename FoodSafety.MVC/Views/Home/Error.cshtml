@model FoodSafety.MVC.Models.ErrorViewModel

@{
    ViewData["Title"] = "Error";
}

<div class="text-center mt-5">
    <h1 class="text-danger mb-3">Something went wrong</h1>
    <p class="lead">An unexpected error occurred while processing your request.</p>
    <p>Please try again later.</p>

    @if (Model.ShowRequestId)
    {
        <p class="mt-3">
            <strong>Request ID:</strong> <code>@Model.RequestId</code>
        </p>
    }

    <div class="mt-4">
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary">Back to Dashboard</a>
    </div>
</div>