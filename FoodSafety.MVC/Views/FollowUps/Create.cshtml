@model FoodSafety.MVC.ViewModels.FollowUpCreateViewModel

@{
    ViewData["Title"] = "Create Follow-Up";
}

<h1 class="mb-4">Create Follow-Up</h1>

<div class="mb-3">
    <p><strong>Premises:</strong> @Model.PremisesName</p>
    <p><strong>Inspection Date:</strong> @Model.InspectionDate.ToString("dd/MM/yyyy")</p>
</div>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <input asp-for="InspectionId" type="hidden" />
    <input asp-for="PremisesId" type="hidden" />
    <input asp-for="PremisesName" type="hidden" />
    <input asp-for="InspectionDate" type="hidden" />

    <div class="mb-3">
        <label asp-for="DueDate" class="form-label"></label>
        <input asp-for="DueDate" class="form-control" />
        <span asp-validation-for="DueDate" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save Follow-Up</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}