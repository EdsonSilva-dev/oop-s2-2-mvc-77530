@model List<FoodSafety.MVC.ViewModels.FollowUpListItemViewModel>
@using FoodSafety.Domain.Enums

@{
    ViewData["Title"] = "Follow-Ups";
}

<h1 class="mb-4">Follow-Ups</h1>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Premises</th>
            <th>Town</th>
            <th>Inspection Date</th>
            <th>Due Date</th>
            <th>Status</th>
            <th>Closed Date</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr class="@(item.IsOverdue ? "table-warning" : "")">
                <td>@item.PremisesName</td>
                <td>@item.Town</td>
                <td>@item.InspectionDate.ToString("dd/MM/yyyy")</td>
                <td>@item.DueDate.ToString("dd/MM/yyyy")</td>
                <td>
                    @if (item.Status == FollowUpStatus.Open)
                    {
                        if (item.IsOverdue)
                        {
                            <span class="badge bg-warning text-dark">Open - Overdue</span>
                        }
                        else
                        {
                            <span class="badge bg-primary">Open</span>
                        }
                    }
                    else
                    {
                        <span class="badge bg-success">Closed</span>
                    }
                </td>
                <td>@(item.ClosedDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                <td>
                    @if (item.Status == FollowUpStatus.Open && (User.IsInRole("Admin") || User.IsInRole("Inspector")))
                    {
                        <a asp-action="Close" asp-route-id="@item.Id" class="btn btn-sm btn-success">Close</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>