@model List<FoodSafety.MVC.ViewModels.InspectionListItemViewModel>
@using FoodSafety.Domain.Enums

@{
    ViewData["Title"] = "Inspections";
}

<h1 class="mb-4">Inspections</h1>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Premises</th>
            <th>Town</th>
            <th>Date</th>
            <th>Score</th>
            <th>Outcome</th>
            <th>Notes</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var inspection in Model)
        {
            <tr>
                <td>@inspection.PremisesName</td>
                <td>@inspection.Town</td>
                <td>@inspection.InspectionDate.ToString("dd/MM/yyyy")</td>
                <td>@inspection.Score</td>
                <td>
                    @if (inspection.Outcome == InspectionOutcome.Fail)
                    {
                        <span class="badge bg-danger">Fail</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Pass</span>
                    }
                </td>
                <td>@inspection.Notes</td>
            </tr>
        }
    </tbody>
</table>